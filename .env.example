# Copy this file to .env and adjust values for your environment.

# Database (SQLite by default; use a PostgreSQL URL in production)
DATABASE_URL=sqlite:///./learning_assistant.db
# DATABASE_URL=postgresql://user:password@localhost:5432/learning_assistant

# JWT settings -- ALWAYS override the secret key in production
SECRET_KEY=change_me_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Frontend -> backend URL (used by the Streamlit dashboard)
API_URL=http://localhost:8000
